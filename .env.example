# Threat Intelligence API Keys

GREYNOISE_API_KEY=your_greynoise_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Optional sources
IPINFO_API_KEY=your_ipinfo_api_key_here

# Application Configuration
LOG_LEVEL=INFO
CACHE_TTL_DAYS=7
DATABASE_PATH=data/cache.db

# API Server
API_HOST=127.0.0.1
API_PORT=8000

# API Authentication (leave empty to disable auth in dev)
API_KEY=

# CORS (comma-separated origins, leave empty to disable CORS)
CORS_ORIGINS=
